<!DOCTYPE html>
<html>
<head>
    <title>NetScan Dashboard</title>

    <style>

        body{
            font-family:Arial;
            background:#111827;
            color:white;
            padding:40px;
        }

        .navbar{
            display:flex;
            justify-content:space-between;
            align-items:center;
            background:#1f2937;
            padding:18px 30px;
            border-radius:10px;
            margin-bottom:30px;
        }

        .navbar h2{
            color:#38bdf8;
            margin:0;
        }

        .nav-links a{
            color:white;
            text-decoration:none;
            margin-left:25px;
            font-weight:bold;
        }

        .nav-links a:hover{
            color:#38bdf8;
        }

        h1{
            color:#38bdf8;
        }

        .cards{
            display:flex;
            gap:25px;
            flex-wrap:wrap;
            margin-top:30px;
        }

        .card{
            flex:1;
            min-width:220px;
            background:#1f2937;
            border-radius:12px;
            padding:25px;
            text-align:center;
        }

        .card h2{
            margin-bottom:15px;
            color:#38bdf8;
        }

        .number{
            font-size:42px;
            font-weight:bold;
        }

        .latest{
            margin-top:40px;
            background:#1f2937;
            padding:25px;
            border-radius:12px;
        }

    </style>

</head>

<body>

<div class="navbar">

    <h2>🛡️ NetScan Dashboard</h2>

    <div class="nav-links">
        <a href="/">🏠 Home</a>
        <a href="/history">📜 History</a>
    </div>

</div>

<h1>Cyber Security Dashboard</h1>

<div class="cards">

    <div class="card">
        <h2>📊 Total Scans</h2>
        <div class="number"><%= totalScans %></div>
    </div>

    <div class="card">
        <h2>🖥 Latest Host</h2>

        <% if(latestScan){ %>

        <div style="font-size:22px;font-weight:bold;">
            <%= latestScan.target %>
        </div>

        <% }else{ %>

        <div class="number">-</div>

        <% } %>

    </div>

    <div class="card">
        <h2>📌 Status</h2>

        <% if(latestScan){ %>

        <div style="font-size:28px;font-weight:bold;color:#22c55e;">
            <%= latestScan.scan_status %>
        </div>

        <% }else{ %>

        <div class="number">-</div>

        <% } %>

    </div>

</div>

<div class="latest">

<h2>Latest Scan</h2>

<% if(latestScan){ %>

<p><strong>Target:</strong> <%= latestScan.target %></p>

<p><strong>IP:</strong> <%= latestScan.ip %></p>

<p><strong>Profile:</strong> <%= latestScan.profile %></p>

<p><strong>Status:</strong> <%= latestScan.scan_status %></p>

<% } else { %>

<p>No scans available.</p>

<% } %>

</div>

</body>
</html>