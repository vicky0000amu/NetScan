<!DOCTYPE html>
<html>
<head>
    <title>Scan Details</title>

    <style>

        body{
            font-family:Arial;
            background:#111;
            color:white;
            padding:40px;
        }

        h1{
            color:#00d9ff;
        }

        .card{
            background:#1b1b1b;
            padding:20px;
            border-radius:10px;
            margin-bottom:30px;
        }

        table{
            width:100%;
            border-collapse:collapse;
        }

        th,td{
            border:1px solid #444;
            padding:12px;
            text-align:left;
        }

        th{
            background:#222;
        }

        tr:nth-child(even){
            background:#1b1b1b;
        }

        a{
            color:#00d9ff;
            text-decoration:none;
        }

    </style>

</head>

<body>

<h1>Scan Details</h1>

<div class="card">

<p><strong>Target:</strong> <%= scan.target %></p>

<p><strong>IP Address:</strong> <%= scan.ip %></p>

<p><strong>Hostname:</strong> <%= scan.hostname %></p>

<p><strong>Profile:</strong> <%= scan.profile %></p>

<p><strong>Status:</strong> <%= scan.scan_status %></p>

</div>

<h2>Open Ports</h2>

<table>

<tr>

<th>Port</th>

<th>Protocol</th>

<th>State</th>

<th>Service</th>

<th>Version</th>

</tr>

<% ports.forEach(port=>{ %>

<tr>

<td><%= port.port %></td>

<td><%= port.protocol %></td>

<td><%= port.state %></td>

<td><%= port.service %></td>

<td><%= port.version %></td>

</tr>

<% }) %>

</table>

<br><br>

<a href="/history">← Back to History</a>

</body>
</html>