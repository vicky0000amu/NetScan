<!DOCTYPE html>
<html>
<head>
    <title>Scan History</title>

    <style>

        body{
            font-family: Arial;
            background:#111;
            color:white;
            padding:40px;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
        }

        th,td{
            border:1px solid #444;
            padding:12px;
            text-align:left;
        }

        th{
            background:#222;
        }

        tr:nth-child(even){
            background:#1b1b1b;
        }

        a{
            color:#00d9ff;
            text-decoration:none;
        }

    </style>

</head>

<body>

<h1>NetScan History</h1>

<table>

<tr>

<th>Target</th>
<th>IP</th>
<th>Hostname</th>
<th>Profile</th>
<th>Status</th>

</tr>

<% scans.forEach(scan=>{ %>

<tr>

<td>
    <a href="/history/<%= scan.id %>">
        <%= scan.target %>
    </a>
</td>

<td><%= scan.ip %></td>

<td><%= scan.hostname %></td>

<td><%= scan.profile %></td>

<td><%= scan.scan_status %></td>

</tr>

<% }) %>

</table>

<br>

<a href="/">← Back to Scanner</a>

</body>

</html>