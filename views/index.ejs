<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NetScan — Nmap Port Scanner</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <nav class="navbar">
    <h2>🛡️ NetScan</h2>

    <div class="nav-links">
        <a href="/">🏠 Home</a>
        <a href="/history">📜 Scan History</a>
    </div>
</nav>

  <div class="scanlines"></div>

  <header class="topbar">
    <div class="brand">
      <span class="brand-dot"></span>
      NET<span class="accent">SCAN</span>
    </div>
    <div class="topbar-sub">nmap-powered · web console</div>
  </header>

  <main class="wrap">

    <section class="panel form-panel">
      <h1>Scan a host</h1>
      <p class="subtitle">Enter a target you own or are explicitly authorized to test.</p>

      <form id="scanForm">
        <label for="target">Target (IP or hostname)</label>
<input
  type="text"
  id="target"
  name="target"
  placeholder="e.g. scanme.nmap.org, google.com or 8.8.8.8"
  autocomplete="off"
  required
/>

<div class="target-note">
  <strong>🌐 Online Scanner (Public Targets Only)</strong>
  Please use the <strong>NetScan Local Agent</strong> to scan private/local network devices (LAN), including routers, PCs, servers, printers, IoT devices, and other hosts using private IP addresses.
  <br><br>

  <strong>Examples:</strong>
  <code>scanme.nmap.org</code>,
  <code>google.com</code>,
  <code>8.8.8.8</code>,
  <code>cloudflare.com</code>,
  <code>example.com</code>.

  <br><br>

  <strong>🏠 Private Networks</strong><br>
  Local/private IP addresses such as
  <code>192.168.x.x</code>,
  <code>10.x.x.x</code>,
  <code>172.16.x.x – 172.31.x.x</code>,
  <code>localhost</code>,
  and devices connected to your Wi-Fi/LAN
  <strong>cannot be scanned using the online version.</strong>

  <br><br>

  Please use the <strong>NetScan Local Agent</strong> to scan private or internal networks.
</div>

        <label for="profile">Scan type</label>
        <select id="profile" name="profile">
          <% profiles.forEach(function(p) { %>
            <option value="<%= p.key %>"><%= p.label %></option>
          <% }); %>
        </select>

        <label class="checkbox-row">
          <input type="checkbox" id="confirmAuthorized" name="confirmAuthorized" required />
          <span>I own this target or have explicit permission to scan it.</span>
        </label>

        <button type="submit" id="scanBtn">
          <span id="btnLabel">Run Scan</span>
        </button>

        <p id="formError" class="error-text"></p>
      </form>
    </section>

    <section class="panel results-panel">
      <div class="results-header">
        <h2>Results</h2>
        <div id="radar" class="radar hidden">
          <div class="radar-ring r1"></div>
          <div class="radar-ring r2"></div>
          <div class="radar-ring r3"></div>
          <div class="radar-sweep"></div>
        </div>
      </div>

      <div id="resultsBody" class="results-body">
        <p class="placeholder">// scan output will appear here</p>
      </div>
    </section>

  </main>

  <footer class="footer">
    Only scan systems you own or are authorized to test. Unauthorized scanning may be illegal in your jurisdiction.
  </footer>

  <script src="/script.js"></script>
</body>
</html>
